# Copy this file to .env.local and fill in values from your cloud resources.
# Never commit .env.local.

AZURE_VISION_ENDPOINT=https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/
AZURE_VISION_KEY=YOUR_AZURE_VISION_KEY

# Optional: used by the deployed Cloudflare Pages Function for Google TTS.
GOOGLE_TTS_API_KEY=YOUR_GOOGLE_CLOUD_TTS_API_KEY
GOOGLE_TTS_VOICE=sv-SE-Chirp3-HD-Aoede
